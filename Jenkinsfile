pipeline {
    agent any

    stages {

        stage('Clone') {
            steps {
                echo 'Code cloned from GitHub'
            }
        }

        stage('Build') {
            steps {
                echo 'Build started'
            }
        }

        stage('Test') {
            steps {
                echo 'Testing application'
            }
        }

        stage('Deploy') {
            steps {
                echo 'Deploying application'
            }
        }
    }
}
